#!/bin/bash

# Configuration
OLLAMA_URL=$(git config --global --get ollama.url || echo "http://localhost:11434")
MODEL=$(git config --global --get ollama.model || echo "mistral")
COMMIT_MSG_FILE=$1
MAX_DIFF_LENGTH=3000
#

ORIGINAL_MSG=$(cat "$COMMIT_MSG_FILE")
if [ -z "$ORIGINAL_MSG" ]; then
    exit 0
fi

DIFF=$(git diff --cached -- . ':(exclude)package-lock.json' ':(exclude)yarn.lock' ':(exclude)*.lock')
if [ -z "$DIFF" ]; then
    exit 0
fi

if [ ${#DIFF} -gt $MAX_DIFF_LENGTH ]; then
    echo "⚠️  Diff trop long, tronqué aux $MAX_DIFF_LENGTH premiers caractères pour Ollama."
    DIFF="${DIFF:0:$MAX_DIFF_LENGTH}\n...(diff truncated)"
fi

echo "🤖 Analyse du code et réécriture du commit avec $MODEL..."

read -r -d '' SYSTEM_PROMPT << 'EOF'
You are a Git Commit Engineer. Generate Conventional Commits from diffs with environment awareness.

CORE RULES:
1. Format: type(scope): imperative-verb description
2. Types: feat, fix, refactor, perf, test, build, ci, docs, style, chore, revert
3. Subject: ≤72 chars, imperative mood (e.g., "add" not "added")
4. Body: Required for prod changes, breaking changes, security fixes

SCOPE DETECTION:
- User-provided scope: use verbatim
- No scope: infer from files (src/auth/ → auth, helm/cluster/ → cluster)
- Environment detected: ALWAYS include in scope or body

ENVIRONMENT DETECTION (HIGH PRIORITY):
Detect environment from file paths and include in commit:
- argocd/prd/ OR deploy/prd/ → [prd] or scope(prd)
- argocd/stg/ OR deploy/stg/ → [stg] or scope(stg)
- argocd/ppr/ OR deploy/ppr/ → [ppr] or scope(ppr)
- argocd/sbx/ OR deploy/sbx/ → [sbx] or scope(sbx)
- Multiple environments → list in body: "Environments: prd, stg"

EXAMPLES:
✅ feat(cnpg/prd): enable backup for a4 cluster
✅ fix(ingress/stg): correct TLS certificate path
✅ build(deps): upgrade cnpg operator to 1.24

   Environments: prd, stg, ppr
✅ chore(renovate): fix json5 syntax error
❌ feat: update cluster (missing environment context)
❌ fix(cnpg): add backup (which environment?)

BODY (when required):
- Production changes: MUST include why + impact + rollback plan
- Multiple files/envs: List affected environments
- Breaking changes: Add BREAKING CHANGE: section
- Security: Never disclose CVE details in subject

SIMPLE CHANGES (<10 lines, non-prod):
- Subject only: "docs(readme): fix typo"

OUTPUT: Raw text, no markdown, no quotes.
EOF

PAYLOAD=$(jq -n \
          --arg model "$MODEL" \
          --arg system "$SYSTEM_PROMPT" \
          --arg msg "$ORIGINAL_MSG" \
          --arg diff "$DIFF" \
          '{
            model: $model,
            stream: false,
            prompt: ($system + "\n\nUSER DRAFT: " + $msg + "\n\nCODE CHANGES:\n" + $diff)
           }')

RESPONSE=$(curl -s -X POST "$OLLAMA_URL/api/generate" \
    -H "Content-Type: application/json" \
    -d "$PAYLOAD")

NEW_MSG=$(echo "$RESPONSE" | jq -r '.response' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
if [ -n "$NEW_MSG" ] && [ "$NEW_MSG" != "null" ]; then
    echo "$NEW_MSG" > "$COMMIT_MSG_FILE"
    echo -e "\033[0;32m✔ Commit transformé :\033[0m"
    echo "  $NEW_MSG"
else
    echo -e "\033[0;31m✘ Erreur Ollama (ou réponse vide). Message original conservé.\033[0m"
fi